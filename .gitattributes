* text=auto
*.go text eol=lf working-tree-encoding=UTF-8
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.toml text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
